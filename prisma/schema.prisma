generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String             @id @default(cuid())
  name                     String
  dealerName               String
  email                    String             @unique
  role                     UserRole           @default(DEALER)
  sessionVersion           Int                @default(0)
  phone                    String
  city                     String?
  businessAddress          String?
  aboutDealer              String?
  lastLoginAt              DateTime?
  loginCount               Int                @default(0)
  reputationScore          Int                @default(100)
  totalListings            Int                @default(0)
  duplicateListings        Int                @default(0)
  spamReports              Int                @default(0)
  spamCount                Int                @default(0)
  duplicateCount           Int                @default(0)
  adminDeletes             Int                @default(0)
  password                 String
  resetToken               String?
  resetTokenExpiry         DateTime?
  referralCode             String?
  hotDealCredits           Int                @default(0)
  futureAdCredits          Int                @default(0)
  referralCounter          Int                @default(0)
  hasUnlockedHotDealReward Boolean            @default(false)
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  listings                 Listing[]
  deleteRequests           DeleteRequest[]
  activityLogs             ActivityLog[]
  reputationLogs           ReputationLog[]
  referralActivities       ReferralActivity[] @relation("DealerReferralActivities")
  referredByActivities     ReferralActivity[] @relation("ReferredUserActivities")

  @@index([createdAt])
  @@index([resetToken])
  @@index([resetTokenExpiry])
}

model Listing {
  id             String    @id @default(cuid())
  title          String
  price          Int
  city           String
  dealerId       String
  plateNumber    String?
  imageHash      String?
  fuel           String?
  km             Int?
  owner          String?
  colour         String?
  transmission   String    @default("Manual")
  insuranceType  String?
  insuranceTill  DateTime?
  remarks        String?
  images         String[]
  boostType      BoostType @default(NORMAL)
  isLive         Boolean   @default(true)
  deletedByAdmin Boolean   @default(false)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  dealer User @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  @@index([dealerId])
  @@index([createdAt])
  @@index([price])
  @@index([city])
  @@index([plateNumber])
  @@index([imageHash])
  @@index([title, price, city])
  @@index([boostType, createdAt])
  @@index([isLive])
  @@index([deletedByAdmin])
  @@index([deletedAt])
  @@index([isLive, boostType, createdAt])
  @@index([dealerId, isLive, createdAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model ReputationLog {
  id          String   @id @default(cuid())
  dealerId    String
  reason      String
  scoreChange Int
  createdAt   DateTime @default(now())

  dealer User @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  @@index([dealerId, createdAt])
  @@index([reason, createdAt])
}

model ReferralActivity {
  id             String   @id @default(cuid())
  dealerId       String
  referredUserId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  dealer       User @relation("DealerReferralActivities", fields: [dealerId], references: [id], onDelete: Cascade)
  referredUser User @relation("ReferredUserActivities", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@unique([dealerId, referredUserId])
  @@index([dealerId, createdAt])
  @@index([referredUserId, createdAt])
}

model DeleteRequest {
  id        String              @id @default(cuid())
  dealerId  String
  reason    String
  status    DeleteRequestStatus @default(PENDING)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  dealer User @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  @@index([dealerId, createdAt])
  @@index([status])
  @@index([status, createdAt])
}

enum BoostType {
  NORMAL
  HOT_DEAL
  FUTURE_AD
}

enum DeleteRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  DEALER
  ADMIN
}
